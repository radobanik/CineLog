<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="CineLog.Mobile.Controls.MoviePosterCard"
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout WidthRequest="115" Spacing="6">
        <Border
            HeightRequest="170"
            BackgroundColor="{StaticResource Surface}"
            Stroke="{StaticResource Border}"
            StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Grid>
                <Image
                    Source="{Binding Source={x:Reference This}, Path=PosterPath}"
                    Aspect="AspectFill" />

                <Grid
                    VerticalOptions="End"
                    Padding="6"
                    BackgroundColor="#70000000">
                    <Label
                        Style="{StaticResource PosterTitleLabel}"
                        Text="{Binding Source={x:Reference This}, Path=Title}"
                        MaxLines="2"
                        LineBreakMode="TailTruncation" />
                </Grid>
            </Grid>
        </Border>

        <Label
            Style="{StaticResource PosterRatingLabel}"
            Text="{Binding Source={x:Reference This}, Path=RatingText, StringFormat='★ {0}'}"
            HorizontalTextAlignment="Center" />
    </VerticalStackLayout>
</ContentView>
