<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="CineLog.Mobile.Controls.NavBar"
    x:Name="This"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid ColumnDefinitions="52, *, 52" HeightRequest="52">

        <Label
            Grid.Column="0"
            FontFamily="FASolid"
            FontSize="18"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Text="{Binding Source={x:Reference This}, Path=LeftIcon}"
            TextColor="{StaticResource OnSurface}">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLeftTapped" />
            </Label.GestureRecognizers>
        </Label>

        <Label
            Grid.Column="1"
            FontAttributes="Bold"
            FontSize="18"
            HorizontalOptions="Center"
            Margin="0,2,0,0"
            VerticalOptions="Center"
            Text="{Binding Source={x:Reference This}, Path=Title}"
            TextColor="{StaticResource OnBackground}" />

    </Grid>

</ContentView>
