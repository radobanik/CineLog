<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="CineLog.Mobile.Controls.ProfileHeaderSkeleton"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:CineLog.Mobile.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
        <controls:SkeletonView WidthRequest="80" HeightRequest="80" CornerRadius="40" />
        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="8">
            <controls:SkeletonView HeightRequest="20" WidthRequest="140" CornerRadius="4" />
            <controls:SkeletonView HeightRequest="14" WidthRequest="200" CornerRadius="4" />
        </VerticalStackLayout>
    </Grid>
</ContentView>
