<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CineLog.Mobile.Pages.Dashboard.DashboardPage"
    x:DataType="vm:DashboardViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Dashboard;assembly=CineLog.Mobile.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dashboard">

    <VerticalStackLayout Padding="28" Spacing="16" VerticalOptions="Center">

        <Label
            HorizontalOptions="Center"
            Style="{StaticResource HeadlineLargeLabel}"
            Text="Dashboard" />

        <Button
            Command="{Binding GoToProfileCommand}"
            HorizontalOptions="Fill"
            Style="{StaticResource PrimaryButton}"
            Text="Go to Profile" />

        <Button
            Command="{Binding LogoutCommand}"
            HorizontalOptions="Fill"
            Style="{StaticResource DangerButton}"
            Text="Log Out" />

    </VerticalStackLayout>

</ContentPage>
