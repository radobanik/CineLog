<?xml version="1.0" encoding="utf-8" ?>
<pages:BasePage
    x:Class="CineLog.Mobile.Pages.Movies.MoviesCategoryPage"
    x:DataType="vm:MoviesCategoryViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:models="clr-namespace:CineLog.Mobile.Core.Models.Home;assembly=CineLog.Mobile.Core"
    xmlns:pages="clr-namespace:CineLog.Mobile.Pages"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Common;assembly=CineLog.Mobile.Core"
    xmlns:controls="clr-namespace:CineLog.Mobile.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0B0D10"
    Shell.NavBarIsVisible="True"
    Shell.BackgroundColor="#00CC44"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White">

    <CollectionView
        ItemsSource="{Binding Movies}"
        SelectionMode="None"
        RemainingItemsThreshold="6"
        RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">

        <CollectionView.ItemsLayout>
            <GridItemsLayout
                Orientation="Vertical"
                Span="3"
                VerticalItemSpacing="12"
                HorizontalItemSpacing="12" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:HomeMovieItem">
                <controls:MoviePosterCardView
                    Title="{Binding Title}"
                    PosterPath="{Binding PosterPath}"
                    RatingText="{Binding RatingText}" />
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.Footer>
            <VerticalStackLayout Padding="0,12,0,24">
                <ActivityIndicator
                    IsVisible="{Binding IsLoadingMore}"
                    IsRunning="{Binding IsLoadingMore}"
                    Color="#00C030"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </CollectionView.Footer>
    </CollectionView>
</pages:BasePage>
