<?xml version="1.0" encoding="utf-8"?>
<ContentPage Shell.NavBarIsVisible="False"
             x:Class="CineLog.Mobile.Pages.Profile.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Profile;assembly=CineLog.Mobile.Core"
             xmlns:models="clr-namespace:CineLog.Mobile.ApiClient.Models;assembly=CineLog.Mobile.ApiClient">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="25">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Label Text="{x:Static helpers:FontAwesomeIcons.ChevronLeft}"
                       Style="{StaticResource IconLabel}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToDashboardCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
                
                <Label Text="Profile" Grid.Column="1"
                       Style="{StaticResource HeadlineLargeLabel}" />
                <Label Grid.Column="2"
                       Text="{x:Static helpers:FontAwesomeIcons.Edit}"
                       Style="{StaticResource IconLabel}" />
            </Grid>
            <HorizontalStackLayout Spacing="15">
                <Border WidthRequest="80"
                        HeightRequest="80"
                        StrokeShape="RoundRectangle 40">
                    <Image Source="{Binding AvatarUrl}" />
                </Border>
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="{Binding Username}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       Grid.Column="1"
                                       IsRunning="{Binding IsBusy}" />
                    <Label Text="{Binding Bio}"
                           TextColor="White"
                           Margin="0,5,0,0" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
            <Border BackgroundColor="#1A1A1A"
                    Padding="15"
                    StrokeShape="RoundRectangle 10">
                <Grid ColumnDefinitions="*, *, *, *">
                    <VerticalStackLayout Grid.Column="0"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding FilmsCount}"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="FILMS"
                               FontSize="10"
                               TextColor="Gray" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="Center">
                        <Label Text="67"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="THIS YEAR"
                               FontSize="10"
                               TextColor="Gray" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2"
                                         HorizontalOptions="Center">
                        <Label Text="12"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="LISTS"
                               FontSize="10"
                               TextColor="Gray" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="3"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding FollowingCount}"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="FOLLOWING"
                               FontSize="10"
                               TextColor="Gray" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
            <VerticalStackLayout Spacing="10">
                <Label Text="FAVORITE FILMS"
                       Style="{StaticResource SectionHeaderLabel}" />
                <CollectionView HeightRequest="150" ItemsSource="{Binding FavouriteMovies}">
                    <CollectionView.EmptyView>
                        <Label Text="No favorite films yet."
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               TextColor="Gray" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border WidthRequest="100"
                                    HeightRequest="150"
                                    StrokeShape="RoundRectangle 8">
                                <Label Text="{Binding Title}"
                                       VerticalOptions="End"
                                       Margin="5"
                                       FontSize="10" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
            <VerticalStackLayout Spacing="15">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="RECENT DIARY"
                           Style="{StaticResource SectionHeaderLabel}" />
                    <Label Grid.Column="1"
                           Text="View all"
                           Style="{StaticResource AccentLabel}" />
                </Grid>
                <CollectionView ItemsSource="{Binding Reviews}">
                    <CollectionView.EmptyView>
                        <Label Text="No recent diary entries."
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               TextColor="Gray" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ReviewResponse">
                            <VerticalStackLayout Margin="0,0,0,15">
                                <Grid ColumnDefinitions="50, 60, *"
                                      ColumnSpacing="15">
                                    <VerticalStackLayout Grid.Column="0"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:%d}'}"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center" />
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:MMM}'}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1"
                                            HeightRequest="80"
                                            StrokeShape="RoundRectangle 5" />
                                    <VerticalStackLayout Grid.Column="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding MovieTitle}"
                                               FontAttributes="Bold" />
                                        <HorizontalStackLayout>
                                            <Label Text="★★★★★"
                                                   TextColor="Green" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                                <BoxView HeightRequest="1"
                                         Color="#333333"
                                         Margin="0,15,0,0" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
