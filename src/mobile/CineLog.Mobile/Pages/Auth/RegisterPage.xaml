<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    Shell.NavBarIsVisible="False"
    x:Class="CineLog.Mobile.Pages.Auth.RegisterPage"
    x:DataType="vm:RegisterViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Auth;assembly=CineLog.Mobile.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="28,56,28,48" Spacing="0">

            <Label
                Margin="0,0,0,24"
                Style="{StaticResource IconLabel}"
                Text="{x:Static helpers:FontAwesomeIcons.ChevronLeft}"
                TextColor="{StaticResource OnBackground}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <Label
                Margin="0,0,0,6"
                Style="{StaticResource HeadlineLargeLabel}"
                Text="Create Account" />
            <Label
                Margin="0,0,0,32"
                Style="{StaticResource CaptionLabel}"
                Text="Join the film community" />

            <Label
                Margin="4,0,0,8"
                Style="{StaticResource OverlineLabel}"
                Text="USERNAME" />
            <Border Style="{StaticResource InputFieldBorder}">
                <Grid ColumnDefinitions="52,*,52">
                    <Label
                        Grid.Column="0"
                        HorizontalOptions="Center"
                        Style="{StaticResource SecondaryIconLabel}"
                        VerticalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.User}" />
                    <Entry
                        Grid.Column="1"
                        Placeholder="filmfanatic"
                        Style="{StaticResource CleanEntry}"
                        Text="{Binding Username}" />
                </Grid>
            </Border>

            <Label
                Margin="4,16,0,8"
                Style="{StaticResource OverlineLabel}"
                Text="EMAIL" />
            <Border Style="{StaticResource InputFieldBorder}">
                <Grid ColumnDefinitions="52,*,52">
                    <Label
                        Grid.Column="0"
                        HorizontalOptions="Center"
                        Style="{StaticResource SecondaryIconLabel}"
                        VerticalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Envelope}" />
                    <Entry
                        Grid.Column="1"
                        Keyboard="Email"
                        Placeholder="you@example.com"
                        Style="{StaticResource CleanEntry}"
                        Text="{Binding Email}" />
                </Grid>
            </Border>

            <Label
                Margin="4,16,0,8"
                Style="{StaticResource OverlineLabel}"
                Text="PASSWORD" />
            <Border Style="{StaticResource InputFieldBorder}">
                <Grid ColumnDefinitions="52,*,52">
                    <Label
                        Grid.Column="0"
                        HorizontalOptions="Center"
                        Style="{StaticResource SecondaryIconLabel}"
                        VerticalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Lock}" />
                    <Entry
                        Grid.Column="1"
                        IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                        Placeholder="••••••••"
                        Style="{StaticResource CleanEntry}"
                        Text="{Binding Password}" />
                    <Label
                        Grid.Column="2"
                        HorizontalOptions="Center"
                        Style="{StaticResource SecondaryIconLabel}"
                        VerticalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Eye}">
                        <Label.Triggers>
                            <DataTrigger
                                Binding="{Binding IsPasswordVisible}"
                                TargetType="Label"
                                Value="True">
                                <Setter Property="Text" Value="{x:Static helpers:FontAwesomeIcons.EyeSlash}" />
                            </DataTrigger>
                        </Label.Triggers>
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <Label
                Margin="4,16,0,8"
                Style="{StaticResource OverlineLabel}"
                Text="CONFIRM PASSWORD" />
            <Border Style="{StaticResource InputFieldBorder}">
                <Grid ColumnDefinitions="52,*,52">
                    <Label
                        Grid.Column="0"
                        HorizontalOptions="Center"
                        Style="{StaticResource SecondaryIconLabel}"
                        VerticalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Lock}" />
                    <Entry
                        Grid.Column="1"
                        IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                        Placeholder="••••••••"
                        Style="{StaticResource CleanEntry}"
                        Text="{Binding ConfirmPassword}" />
                    <Label
                        Grid.Column="2"
                        HorizontalOptions="Center"
                        Style="{StaticResource SecondaryIconLabel}"
                        VerticalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Eye}">
                        <Label.Triggers>
                            <DataTrigger
                                Binding="{Binding IsConfirmPasswordVisible}"
                                TargetType="Label"
                                Value="True">
                                <Setter Property="Text" Value="{x:Static helpers:FontAwesomeIcons.EyeSlash}" />
                            </DataTrigger>
                        </Label.Triggers>
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordVisibilityCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <HorizontalStackLayout Margin="0,20,0,0" Spacing="10">
                <CheckBox IsChecked="{Binding IsTermsAccepted}" VerticalOptions="Center" />
                <Label Style="{StaticResource BodyMediumLabel}" VerticalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="I agree to the " TextColor="{StaticResource TextSecondary}" />
                            <Span Text="Terms of Service" TextColor="{StaticResource Primary}" />
                            <Span Text=" and " TextColor="{StaticResource TextSecondary}" />
                            <Span Text="Privacy Policy" TextColor="{StaticResource Primary}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>

            <Button
                Command="{Binding RegisterCommand}"
                HorizontalOptions="Fill"
                Margin="0,24,0,0"
                Style="{StaticResource PrimaryButton}"
                Text="Create Account" />

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Margin="0,16,0,0" />

            <HorizontalStackLayout
                HorizontalOptions="Center"
                Margin="0,32,0,0"
                Spacing="4">
                <Label
                    Style="{StaticResource CaptionLabel}"
                    Text="Already have an account?"
                    VerticalOptions="Center" />
                <Label
                    Style="{StaticResource AccentLabel}"
                    Text="Sign In"
                    VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
