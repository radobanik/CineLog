<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CineLog.Mobile.Pages.Auth.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Auth;assembly=CineLog.Mobile.Core"
    x:DataType="vm:RegisterViewModel"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="28,56,28,48" Spacing="0">

            <Label
                Text="{x:Static helpers:FontAwesomeIcons.ChevronLeft}"
                FontFamily="FASolid"
                TextColor="{StaticResource OnBackground}"
                FontSize="20"
                Margin="0,0,0,24">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <Label
                Text="Create Account"
                Style="{StaticResource HeadlineLarge}"
                Margin="0,0,0,6" />
            <Label
                Text="Join the film community"
                Style="{StaticResource Caption}"
                Margin="0,0,0,32" />

            <Label
                Text="USERNAME"
                FontSize="11"
                FontAttributes="Bold"
                CharacterSpacing="1.2"
                TextTransform="Uppercase"
                TextColor="{StaticResource TextSecondary}"
                Margin="4,0,0,8" />
            <Border Style="{StaticResource InputField}">
                <Grid ColumnDefinitions="52,*">
                    <Label
                        Grid.Column="0"
                        Text="{x:Static helpers:FontAwesomeIcons.User}"
                        FontFamily="FASolid"
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="16"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                    <Entry
                        Grid.Column="1"
                        Style="{StaticResource CleanEntry}"
                        Placeholder="filmfanatic"
                        Text="{Binding Username}" />
                </Grid>
            </Border>

            <Label
                Text="EMAIL"
                FontSize="11"
                FontAttributes="Bold"
                CharacterSpacing="1.2"
                TextTransform="Uppercase"
                TextColor="{StaticResource TextSecondary}"
                Margin="4,16,0,8" />
            <Border Style="{StaticResource InputField}">
                <Grid ColumnDefinitions="52,*">
                    <Label
                        Grid.Column="0"
                        Text="{x:Static helpers:FontAwesomeIcons.Envelope}"
                        FontFamily="FASolid"
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="16"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                    <Entry
                        Grid.Column="1"
                        Style="{StaticResource CleanEntry}"
                        Placeholder="you@example.com"
                        Keyboard="Email"
                        Text="{Binding Email}" />
                </Grid>
            </Border>

            <Label
                Text="PASSWORD"
                FontSize="11"
                FontAttributes="Bold"
                CharacterSpacing="1.2"
                TextTransform="Uppercase"
                TextColor="{StaticResource TextSecondary}"
                Margin="4,16,0,8" />
            <Border Style="{StaticResource InputField}">
                <Grid ColumnDefinitions="52,*,52">
                    <Label
                        Grid.Column="0"
                        Text="{x:Static helpers:FontAwesomeIcons.Lock}"
                        FontFamily="FASolid"
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="16"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                    <Entry
                        Grid.Column="1"
                        Style="{StaticResource CleanEntry}"
                        Placeholder="••••••••"
                        IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                        Text="{Binding Password}" />
                    <Label
                        Grid.Column="2"
                        Text="{x:Static helpers:FontAwesomeIcons.Eye}"
                        FontFamily="FASolid"
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="16"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsPasswordVisible}" Value="True">
                                <Setter Property="Text" Value="{x:Static helpers:FontAwesomeIcons.EyeSlash}" />
                            </DataTrigger>
                        </Label.Triggers>
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <Label
                Text="CONFIRM PASSWORD"
                FontSize="11"
                FontAttributes="Bold"
                CharacterSpacing="1.2"
                TextTransform="Uppercase"
                TextColor="{StaticResource TextSecondary}"
                Margin="4,16,0,8" />
            <Border Style="{StaticResource InputField}">
                <Grid ColumnDefinitions="52,*,52">
                    <Label
                        Grid.Column="0"
                        Text="{x:Static helpers:FontAwesomeIcons.Lock}"
                        FontFamily="FASolid"
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="16"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                    <Entry
                        Grid.Column="1"
                        Style="{StaticResource CleanEntry}"
                        Placeholder="••••••••"
                        IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                        Text="{Binding ConfirmPassword}" />
                    <Label
                        Grid.Column="2"
                        Text="{x:Static helpers:FontAwesomeIcons.Eye}"
                        FontFamily="FASolid"
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="16"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsConfirmPasswordVisible}" Value="True">
                                <Setter Property="Text" Value="{x:Static helpers:FontAwesomeIcons.EyeSlash}" />
                            </DataTrigger>
                        </Label.Triggers>
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordVisibilityCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <HorizontalStackLayout Spacing="10" Margin="0,20,0,0">
                <CheckBox IsChecked="{Binding IsTermsAccepted}" VerticalOptions="Center" />
                <Label VerticalOptions="Center" FontSize="13">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="I agree to the " TextColor="{StaticResource TextSecondary}" />
                            <Span Text="Terms of Service" TextColor="{StaticResource Primary}" />
                            <Span Text=" and " TextColor="{StaticResource TextSecondary}" />
                            <Span Text="Privacy Policy" TextColor="{StaticResource Primary}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>

            <Button
                Text="Create Account"
                Style="{StaticResource PrimaryButton}"
                Command="{Binding RegisterCommand}"
                HorizontalOptions="Fill"
                Margin="0,24,0,0" />

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Margin="0,16,0,0" />

            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="4"
                Margin="0,32,0,0">
                <Label
                    Text="Already have an account?"
                    Style="{StaticResource Caption}"
                    VerticalOptions="Center" />
                <Label
                    Text="Sign In"
                    Style="{StaticResource AccentLabel}"
                    FontSize="13"
                    VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
