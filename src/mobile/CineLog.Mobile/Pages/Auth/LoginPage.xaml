<?xml version="1.0" encoding="utf-8" ?>
<pages:BasePage
    Shell.NavBarIsVisible="False"
    x:Class="CineLog.Mobile.Pages.Auth.LoginPage"
    x:DataType="vm:LoginViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
    xmlns:pages="clr-namespace:CineLog.Mobile.Pages"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Auth;assembly=CineLog.Mobile.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="28,64,28,48" Spacing="0">
            <Border
                BackgroundColor="{StaticResource Primary}"
                HeightRequest="80"
                HorizontalOptions="Center"
                Margin="0,0,0,16"
                StrokeThickness="0"
                WidthRequest="80">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Label
                    Style="{StaticResource IconLabel}"
                    FontSize="54"
                    HorizontalOptions="Center"
                    Text="{x:Static helpers:FontAwesomeIcons.Film}"
                    TextColor="White"
                    VerticalOptions="Center" />
            </Border>

            <Label
                HorizontalOptions="Center"
                Margin="0,0,0,6"
                Style="{StaticResource HeadlineLargeLabel}"
                Text="CineLog" />
            <Label
                HorizontalOptions="Center"
                Margin="0,0,0,48"
                Style="{StaticResource CaptionLabel}"
                Text="Track films you love" />

            <Label
                Margin="0,0,0,24"
                Style="{StaticResource HeadlineMediumLabel}"
                Text="Sign In" />

            <Label
                Margin="4,0,0,8"
                Style="{StaticResource OverlineLabel}"
                Text="EMAIL" />

            <Border Style="{StaticResource InputFieldBorder}">
                <Grid ColumnDefinitions="52,*,52">
                    <Label
                        Grid.Column="0"
                        HorizontalOptions="Center"
                        Style="{StaticResource SecondaryIconLabel}"
                        VerticalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Envelope}" />
                    <Entry
                        Grid.Column="1"
                        Keyboard="Email"
                        Placeholder="you@example.com"
                        Style="{StaticResource CleanEntry}"
                        Text="{Binding Email}" />
                </Grid>
            </Border>

            <Label
                Margin="4,16,0,8"
                Style="{StaticResource OverlineLabel}"
                Text="PASSWORD" />

            <Border Style="{StaticResource InputFieldBorder}">
                <Grid ColumnDefinitions="52,*,52">
                    <Label
                        Grid.Column="0"
                        HorizontalOptions="Center"
                        Style="{StaticResource SecondaryIconLabel}"
                        VerticalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Lock}" />
                    <Entry
                        Grid.Column="1"
                        IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                        Placeholder="••••••••"
                        Style="{StaticResource CleanEntry}"
                        Text="{Binding Password}" />
                    <Label
                        Grid.Column="2"
                        HorizontalOptions="Center"
                        Style="{StaticResource SecondaryIconLabel}"
                        VerticalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Eye}">
                        <Label.Triggers>
                            <DataTrigger
                                Binding="{Binding IsPasswordVisible}"
                                TargetType="Label"
                                Value="True">
                                <Setter Property="Text" Value="{x:Static helpers:FontAwesomeIcons.EyeSlash}" />
                            </DataTrigger>
                        </Label.Triggers>
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <Button
                Command="{Binding LoginCommand}"
                HorizontalOptions="Fill"
                Margin="0,32,0,0"
                Style="{StaticResource PrimaryButton}"
                Text="Sign In" />

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Margin="0,16,0,0" />

            <HorizontalStackLayout
                HorizontalOptions="Center"
                Margin="0,40,0,0"
                Spacing="4">
                <Label
                    Style="{StaticResource CaptionLabel}"
                    Text="Don't have an account?"
                    VerticalOptions="Center" />
                <Label
                    Style="{StaticResource AccentLabel}"
                    Text="Sign Up"
                    VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</pages:BasePage>
