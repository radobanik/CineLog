<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CineLog.Mobile.Pages.Auth.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Auth;assembly=CineLog.Mobile.Core"
    x:DataType="vm:LoginViewModel"
    Shell.NavBarIsVisible="False">

    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout
                Padding="32,60,32,32"
                Spacing="0"
                VerticalOptions="Center">

                <!-- Logo / Brand -->
                <Label
                    HorizontalOptions="Center"
                    Margin="0,0,0,8"
                    Style="{StaticResource PrimaryIcon}"
                    FontSize="56"
                    Text="{x:Static helpers:FontAwesomeIcons.Film}" />

                <Label
                    HorizontalOptions="Center"
                    Margin="0,0,0,48"
                    Style="{StaticResource HeadlineLarge}"
                    Text="CineLog" />

                <!-- Email -->
                <Grid ColumnDefinitions="44,*" Margin="0,0,0,0">
                    <Label
                        Grid.Column="0"
                        Style="{StaticResource Icon}"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Envelope}" />
                    <Entry
                        Grid.Column="1"
                        Style="{StaticResource FormEntry}"
                        Placeholder="Email"
                        Keyboard="Email"
                        Text="{Binding Email}" />
                </Grid>

                <!-- Password -->
                <Grid ColumnDefinitions="44,*" Margin="0,8,0,0">
                    <Label
                        Grid.Column="0"
                        Style="{StaticResource Icon}"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Lock}" />
                    <Entry
                        Grid.Column="1"
                        Style="{StaticResource FormEntry}"
                        Placeholder="Password"
                        IsPassword="True"
                        Text="{Binding Password}" />
                </Grid>

                <!-- Login button -->
                <Button
                    Margin="0,32,0,0"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoginCommand}"
                    Text="Sign In" />

                <!-- Busy indicator -->
                <ActivityIndicator
                    Margin="0,16,0,0"
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}" />

                <!-- Register link -->
                <HorizontalStackLayout
                    Margin="0,24,0,0"
                    HorizontalOptions="Center"
                    Spacing="4">
                    <Label
                        Style="{StaticResource BodyMedium}"
                        VerticalOptions="Center"
                        Text="Don't have an account?" />
                    <Button
                        Style="{StaticResource TextButton}"
                        Command="{Binding GoToRegisterCommand}"
                        Text="Sign Up" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>

</ContentPage>
