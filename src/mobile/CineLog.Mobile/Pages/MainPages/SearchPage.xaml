<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
             x:Class="CineLog.Mobile.Pages.MainPages.SearchPage"
             Shell.NavBarIsVisible="False"
             Title="SearchPage">

    <Grid Padding="28">
        <VerticalStackLayout
            Spacing="12"
            VerticalOptions="Center">

            <Label
                HorizontalOptions="Center"
                Style="{StaticResource PrimaryIconLabel}"
                FontSize="40"
                Text="{x:Static helpers:FontAwesomeIcons.Search}" />

            <Label
                HorizontalOptions="Center"
                Style="{StaticResource HeadlineLargeLabel}"
                Text="Search" />

            <Label
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Style="{StaticResource CaptionLabel}"
                Text="Placeholder for now" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>
