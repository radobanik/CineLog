<?xml version="1.0" encoding="utf-8" ?>
<pages:BasePage
    x:Class="CineLog.Mobile.Pages.MainPages.SearchPage"
    x:DataType="vm:SearchViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:CineLog.Mobile.Controls"
    xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
    xmlns:home="clr-namespace:CineLog.Mobile.Core.Models.Home;assembly=CineLog.Mobile.Core"
    xmlns:search="clr-namespace:CineLog.Mobile.Core.Models.Search;assembly=CineLog.Mobile.Core"
    xmlns:pages="clr-namespace:CineLog.Mobile.Pages"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Search;assembly=CineLog.Mobile.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BackgroundDeep}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *" Padding="16,20,16,0">

        <VerticalStackLayout Grid.Row="0" Spacing="12" Margin="0,0,0,16">

            <Label Style="{StaticResource PageTitleLabel}" Text="Search" />

            <Border Style="{StaticResource InputFieldBorder}">
                <Grid ColumnDefinitions="Auto, *, Auto" Padding="16,0">
                    <Label
                        Grid.Column="0"
                        FontFamily="FASolid"
                        FontSize="15"
                        Text="{x:Static helpers:FontAwesomeIcons.Search}"
                        TextColor="{StaticResource TextSecondary}"
                        VerticalOptions="Center" />
                    <Entry
                        Grid.Column="1"
                        Style="{StaticResource CleanEntry}"
                        Placeholder="Movies, people..."
                        Text="{Binding SearchQuery}"
                        Margin="10,0" />
                    <Label
                        Grid.Column="2"
                        FontFamily="FASolid"
                        FontSize="15"
                        Text="{x:Static helpers:FontAwesomeIcons.Times}"
                        TextColor="{StaticResource TextSecondary}"
                        VerticalOptions="Center"
                        IsVisible="{Binding HasQuery}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

        </VerticalStackLayout>

        <Grid Grid.Row="1">

            <VerticalStackLayout
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="12"
                IsVisible="{Binding ShowEmptyState}">
                <Label
                    FontFamily="FASolid"
                    FontSize="40"
                    HorizontalOptions="Center"
                    Text="{x:Static helpers:FontAwesomeIcons.Search}"
                    TextColor="{StaticResource Primary}" />
                <Label
                    Style="{StaticResource BodyMediumLabel}"
                    HorizontalOptions="Center"
                    Text="Search for movies and people" />
            </VerticalStackLayout>

            <ActivityIndicator
                VerticalOptions="Center"
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />

            <ScrollView IsVisible="{Binding HasResults}">
                <VerticalStackLayout Spacing="20" Padding="0,0,0,24">

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasMovies}">
                        <Label Style="{StaticResource SectionHeaderLabel}" Text="Movies" />
                        <CollectionView ItemsSource="{Binding Movies}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="home:MovieItem">
                                    <controls:MoviePosterCard
                                        Title="{Binding Title}"
                                        PosterPath="{Binding PosterPath}"
                                        RatingText="{Binding RatingText}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasPeople}">
                        <Label Style="{StaticResource SectionHeaderLabel}" Text="People" />
                        <CollectionView ItemsSource="{Binding People}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="search:PersonItem">
                                    <VerticalStackLayout WidthRequest="90" Spacing="6">
                                        <Border
                                            HeightRequest="90"
                                            WidthRequest="90"
                                            BackgroundColor="{StaticResource Surface}"
                                            StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="45" />
                                            </Border.StrokeShape>
                                            <Image
                                                Source="{Binding ProfilePath}"
                                                Aspect="AspectFill" />
                                        </Border>
                                        <Label
                                            Style="{StaticResource PosterTitleLabel}"
                                            Text="{Binding Name}"
                                            HorizontalTextAlignment="Center"
                                            MaxLines="2"
                                            LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <VerticalStackLayout
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="8"
                IsVisible="{Binding ShowNoResults}">
                <Label
                    Style="{StaticResource BodyMediumLabel}"
                    HorizontalOptions="Center"
                    Text="No results found" />
                <Label
                    Style="{StaticResource CaptionLabel}"
                    HorizontalOptions="Center"
                    Text="Try a different search term" />
            </VerticalStackLayout>

        </Grid>
    </Grid>
</pages:BasePage>
