<?xml version="1.0" encoding="utf-8"?>
<pages:BasePage
    x:Class="CineLog.Mobile.Pages.MainPages.ProfilePage"
    x:DataType="vm:ProfileViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
    xmlns:home="clr-namespace:CineLog.Mobile.Core.Models.Home;assembly=CineLog.Mobile.Core"
    xmlns:review="clr-namespace:CineLog.Mobile.Core.Models.Review;assembly=CineLog.Mobile.Core"
    xmlns:pages="clr-namespace:CineLog.Mobile.Pages"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Profile;assembly=CineLog.Mobile.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Grid ColumnDefinitions="*, Auto">
                <Label
                    Style="{StaticResource HeadlineLargeLabel}"
                    Text="Profile" />
                <Label
                    Grid.Column="1"
                    Style="{StaticResource IconLabel}"
                    Text="{x:Static helpers:FontAwesomeIcons.Edit}"
                    Padding="10" />
            </Grid>

            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                <Border
                    WidthRequest="80"
                    HeightRequest="80"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40" />
                    </Border.StrokeShape>
                    <Image Source="{Binding AvatarUrl}" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label
                        Style="{StaticResource HeadlineMediumLabel}"
                        Text="{Binding Username}" />
                    <Label
                        Style="{StaticResource BodyMediumLabel}"
                        Text="{Binding Bio}"
                        Margin="0,5,0,0" />
                </VerticalStackLayout>
            </Grid>

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />

            <Border
                Padding="15"
                BackgroundColor="{StaticResource Surface}"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*, *, *, *">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                        <Label
                            Style="{StaticResource HeadlineMediumLabel}"
                            Text="{Binding FilmsCount}"
                            HorizontalOptions="Center" />
                        <Label Style="{StaticResource OverlineLabel}" Text="FILMS" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                        <Label
                            Style="{StaticResource HeadlineMediumLabel}"
                            Text="67"
                            HorizontalOptions="Center" />
                        <Label Style="{StaticResource OverlineLabel}" Text="THIS YEAR" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                        <Label
                            Style="{StaticResource HeadlineMediumLabel}"
                            Text="{Binding FollowersCount}"
                            HorizontalOptions="Center" />
                        <Label Style="{StaticResource OverlineLabel}" Text="FOLLOWERS" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                        <Label
                            Style="{StaticResource HeadlineMediumLabel}"
                            Text="{Binding FollowingCount}"
                            HorizontalOptions="Center" />
                        <Label Style="{StaticResource OverlineLabel}" Text="FOLLOWING" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource SectionHeaderLabel}" Text="FAVORITE FILMS" />
                <CollectionView ItemsSource="{Binding FavouriteMovies}">
                    <CollectionView.EmptyView>
                        <Label
                            Style="{StaticResource CaptionLabel}"
                            Text="No favorite films yet."
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="home:MovieItem">
                            <MoviePosterCard
                                Title="{Binding Title}"
                                PosterPath="{Binding PosterPath}"
                                RatingText="{Binding RatingText}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="15">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Style="{StaticResource SectionHeaderLabel}" Text="RECENT DIARY" />
                    <Label
                        Grid.Column="1"
                        Style="{StaticResource AccentLabel}"
                        Text="View all" />
                </Grid>
                <CollectionView ItemsSource="{Binding Reviews}">
                    <CollectionView.EmptyView>
                        <Label
                            Style="{StaticResource CaptionLabel}"
                            Text="No recent diary entries."
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="review:ReviewItem">
                            <VerticalStackLayout Margin="0,0,0,15">
                                <Grid ColumnDefinitions="50, *, Auto" ColumnSpacing="15">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label
                                            Style="{StaticResource HeadlineMediumLabel}"
                                            Text="{Binding CreatedAt, StringFormat='{0:%d}'}"
                                            HorizontalOptions="Center" />
                                        <Label
                                            Style="{StaticResource CaptionLabel}"
                                            Text="{Binding CreatedAt, StringFormat='{0:MMM}'}"
                                            HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="6">
                                            <Label
                                                Style="{StaticResource BodyLargeLabel}"
                                                Text="{Binding MovieTitle}"
                                                FontAttributes="Bold" />
                                            <Label
                                                Style="{StaticResource RatingLabel}"
                                                Text="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                        <Label
                                            Style="{StaticResource CaptionLabel}"
                                            Text="{Binding ReviewText}" />
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="4">
                                        <Label
                                            Style="{StaticResource CaptionLabel}"
                                            Text="{Binding LikesCount}" />
                                        <Label
                                            Style="{StaticResource SecondaryIconLabel}"
                                            Text="{x:Static helpers:FontAwesomeIcons.ThumbsUp}" />
                                    </HorizontalStackLayout>
                                </Grid>
                                <BoxView Style="{StaticResource ListDivider}" Margin="0,15,0,0" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</pages:BasePage>
