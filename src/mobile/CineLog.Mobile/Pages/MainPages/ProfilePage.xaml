<?xml version="1.0" encoding="utf-8"?>
<pages:BasePage Shell.NavBarIsVisible="False"
               x:Class="CineLog.Mobile.Pages.MainPages.ProfilePage"
               x:DataType="vm:ProfileViewModel"
               xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
               xmlns:pages="clr-namespace:CineLog.Mobile.Pages"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Profile;assembly=CineLog.Mobile.Core"
               xmlns:models="clr-namespace:CineLog.Mobile.ApiClient.Models;assembly=CineLog.Mobile.ApiClient">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="25">
            <Grid ColumnDefinitions="*, Auto">
                <Label Text="Profile"
                       Style="{StaticResource HeadlineLargeLabel}" />
                <Label Grid.Column="1"
                       Text="{x:Static helpers:FontAwesomeIcons.Edit}"
                       Style="{StaticResource IconLabel}" />
            </Grid>
            <Grid ColumnDefinitions="80, *"
                  ColumnSpacing="15">
                <Border WidthRequest="80"
                        HeightRequest="80"
                        StrokeShape="RoundRectangle 40">
                    <Image Source="{Binding AvatarUrl}" />
                </Border>
                <VerticalStackLayout Grid.Column="1"
                                     VerticalOptions="Center">
                    <Label Text="{Binding Username}"
                           Style="{StaticResource HeadlineMediumLabel}" />
                    <Label Text="{Binding Bio}"
                           Style="{StaticResource BodyMediumLabel}"
                           Margin="0,5,0,0" />
                </VerticalStackLayout>
            </Grid>
            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               HorizontalOptions="Center" />
            <Border BackgroundColor="{StaticResource Surface}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10">
                <Grid ColumnDefinitions="*, *, *, *">
                    <VerticalStackLayout Grid.Column="0"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding FilmsCount}"
                               Style="{StaticResource HeadlineMediumLabel}"
                               HorizontalOptions="Center" />
                        <Label Text="FILMS"
                               Style="{StaticResource OverlineLabel}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="Center">
                        <Label Text="67"
                               Style="{StaticResource HeadlineMediumLabel}"
                               HorizontalOptions="Center" />
                        <Label Text="THIS YEAR"
                               Style="{StaticResource OverlineLabel}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding FollowersCount}"
                               Style="{StaticResource HeadlineMediumLabel}"
                               HorizontalOptions="Center" />
                        <Label Text="FOLLOWERS"
                               Style="{StaticResource OverlineLabel}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="3"
                                         HorizontalOptions="Center">
                        <Label Text="{Binding FollowingCount}"
                               Style="{StaticResource HeadlineMediumLabel}"
                               HorizontalOptions="Center" />
                        <Label Text="FOLLOWING"
                               Style="{StaticResource OverlineLabel}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
            <VerticalStackLayout Spacing="10">
                <Label Text="FAVORITE FILMS"
                       Style="{StaticResource SectionHeaderLabel}" />
                <CollectionView HeightRequest="150" ItemsSource="{Binding FavouriteMovies}">
                    <CollectionView.EmptyView>
                        <Label Text="No favorite films yet."
                               Style="{StaticResource CaptionLabel}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MovieListItemResponse">
                            <Border WidthRequest="100"
                                    HeightRequest="150"
                                    StrokeShape="RoundRectangle 8">
                                <Grid>
                                    <Image Source="{Binding PosterPath}"
                                           Aspect="AspectFill" />
                                    <Label Text="{Binding Title}"
                                           Style="{StaticResource CaptionLabel}"
                                           VerticalOptions="End"
                                           Margin="5" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
            <VerticalStackLayout Spacing="15">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="RECENT DIARY"
                           Style="{StaticResource SectionHeaderLabel}" />
                    <Label Grid.Column="1"
                           Text="View all"
                           Style="{StaticResource AccentLabel}" />
                </Grid>
                <CollectionView ItemsSource="{Binding Reviews}">
                    <CollectionView.EmptyView>
                        <Label Text="No recent diary entries."
                               Style="{StaticResource CaptionLabel}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ReviewResponse">
                            <VerticalStackLayout Margin="0,0,0,15">
                                <Grid ColumnDefinitions="50, *, Auto"
                                      ColumnSpacing="15">
                                    <VerticalStackLayout Grid.Column="0"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:%d}'}"
                                               Style="{StaticResource HeadlineMediumLabel}"
                                               HorizontalOptions="Center" />
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:MMM}'}"
                                               Style="{StaticResource CaptionLabel}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding MovieTitle}"
                                                   Style="{StaticResource BodyLargeLabel}"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}"
                                                   Style="{StaticResource RatingLabel}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding ReviewText}"
                                               Style="{StaticResource CaptionLabel}" />
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Grid.Column="2"
                                                           VerticalOptions="Center"
                                                           Spacing="4">
                                        <Label Text="{Binding LikesCount}"
                                               Style="{StaticResource CaptionLabel}" />
                                        <Label Text="{x:Static helpers:FontAwesomeIcons.ThumbsUp}"
                                               Style="{StaticResource SecondaryIconLabel}" />
                                    </HorizontalStackLayout>
                                </Grid>
                                <BoxView HeightRequest="1"
                                         Color="{StaticResource Divider}"
                                         Margin="0,15,0,0" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</pages:BasePage>
