<?xml version="1.0" encoding="utf-8" ?>
<pages:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:CineLog.Mobile.Pages"
             x:Class="CineLog.Mobile.Pages.MainPages.LogPage"
             xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
             Shell.NavBarIsVisible="False"
             Title="Log">
    
    <Grid Padding="28">
        <VerticalStackLayout
            Spacing="12"
            VerticalOptions="Center">

            <Label
                HorizontalOptions="Center"
                Style="{StaticResource PrimaryIconLabel}"
                FontSize="40"
                Text="{x:Static helpers:FontAwesomeIcons.Film}" />

            <Label
                HorizontalOptions="Center"
                Style="{StaticResource HeadlineLargeLabel}"
                Text="Log" />

            <Label
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Style="{StaticResource CaptionLabel}"
                Text="Placeholder" />

        </VerticalStackLayout>
    </Grid>
</pages:BasePage>
