<?xml version="1.0" encoding="utf-8" ?>
<pages:BasePage
    x:Class="CineLog.Mobile.Pages.MainPages.HomePage"
    x:DataType="vm:HomeViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
    xmlns:pages="clr-namespace:CineLog.Mobile.Pages"
    xmlns:controls="clr-namespace:CineLog.Mobile.Controls"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Home;assembly=CineLog.Mobile.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0B0D10">

    <ScrollView>
        <VerticalStackLayout Padding="16,20,16,24" Spacing="18">

            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Border
                    BackgroundColor="{StaticResource Primary}"
                    HeightRequest="28"
                    StrokeThickness="0"
                    WidthRequest="28">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Label
                        FontFamily="FASolid"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Film}"
                        TextColor="White"
                        VerticalOptions="Center" />
                </Border>

                <Label
                    Text="CineLog"
                    FontSize="26"
                    FontAttributes="Bold"
                    TextColor="White"
                    VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <Label
                Text="Movies"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White" />

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#00C030" />

            <Label
                IsVisible="{Binding HasError}"
                Text="{Binding ErrorMessage}"
                TextColor="#B3B3B3"
                FontSize="12" />

            <controls:MovieRail
                Title="Top Rated"
                ItemsSource="{Binding TopRatedMovies}"
                LoadMoreCommand="{Binding LoadMoreTopRatedCommand}"
                SeeAllCommand="{Binding GoToTopRatedCommand}"
                IsLoadingMore="{Binding IsLoadingMoreTopRated}" />      

            <BoxView HeightRequest="1" Color="#1F252C" />

            <controls:MovieRail
                Title="New Releases"
                ItemsSource="{Binding NewReleaseMovies}"
                LoadMoreCommand="{Binding LoadMoreNewReleasesCommand}"
                SeeAllCommand="{Binding GoToNewReleasesCommand}"
                IsLoadingMore="{Binding IsLoadingMoreNewReleases}" />

        </VerticalStackLayout>
    </ScrollView>
</pages:BasePage>
