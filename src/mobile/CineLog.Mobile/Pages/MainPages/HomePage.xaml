<?xml version="1.0" encoding="utf-8" ?>
<pages:BasePage
    x:Class="CineLog.Mobile.Pages.MainPages.HomePage"
    x:DataType="vm:HomeViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:helpers="clr-namespace:CineLog.Mobile.Helpers"
    xmlns:pages="clr-namespace:CineLog.Mobile.Pages"
    xmlns:vm="clr-namespace:CineLog.Mobile.Core.ViewModels.Home;assembly=CineLog.Mobile.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BackgroundDeep}"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="16,20,16,24" Spacing="18">

            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Border
                    BackgroundColor="{StaticResource Primary}"
                    HeightRequest="28"
                    StrokeThickness="0"
                    WidthRequest="28">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Label
                        FontFamily="FASolid"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="{x:Static helpers:FontAwesomeIcons.Film}"
                        TextColor="{StaticResource OnPrimary}"
                        VerticalOptions="Center" />
                </Border>

                <Label
                    Style="{StaticResource HeadlineLargeLabel}"
                    Text="CineLog"
                    VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <Label
                Style="{StaticResource PageTitleLabel}"
                Text="Movies" />

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}" />

            <Label
                Style="{StaticResource CaptionLabel}"
                IsVisible="{Binding HasError}"
                Text="{Binding ErrorMessage}" />

            <MovieCarousel
                Title="Top Rated"
                ItemsSource="{Binding TopRatedMovies}"
                LoadMoreCommand="{Binding LoadMoreTopRatedCommand}"
                SeeAllCommand="{Binding GoToTopRatedCommand}"
                IsLoadingMore="{Binding IsLoadingMoreTopRated}" />

            <BoxView Style="{StaticResource ListDivider}" />

            <MovieCarousel
                Title="New Releases"
                ItemsSource="{Binding NewReleaseMovies}"
                LoadMoreCommand="{Binding LoadMoreNewReleasesCommand}"
                SeeAllCommand="{Binding GoToNewReleasesCommand}"
                IsLoadingMore="{Binding IsLoadingMoreNewReleases}" />

        </VerticalStackLayout>
    </ScrollView>
</pages:BasePage>
