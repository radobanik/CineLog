<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--  Primary  -->
    <Color x:Key="Primary">#00CC44</Color>
    <Color x:Key="PrimaryDark">#009933</Color>
    <Color x:Key="PrimaryLight">#33FF66</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>

    <!--  Backgrounds  -->
    <Color x:Key="Background">#0D0D0D</Color>
    <Color x:Key="BackgroundDeep">#0B0D10</Color>
    <Color x:Key="Surface">#1A1A1A</Color>
    <Color x:Key="SurfaceVariant">#242424</Color>
    <Color x:Key="Overlay">#2E2E2E</Color>

    <!--  Text  -->
    <Color x:Key="OnBackground">#FFFFFF</Color>
    <Color x:Key="OnSurface">#EEEEEE</Color>
    <Color x:Key="TextSecondary">#9E9E9E</Color>
    <Color x:Key="TextDisabled">#616161</Color>

    <!--  Semantic  -->
    <Color x:Key="Error">#CF6679</Color>
    <Color x:Key="OnError">#FFFFFF</Color>
    <Color x:Key="Success">#00CC44</Color>
    <Color x:Key="Warning">#FF9800</Color>

    <!--  Borders / Dividers  -->
    <Color x:Key="Border">#2A2A2A</Color>
    <Color x:Key="Divider">#1F1F1F</Color>

</ResourceDictionary>
