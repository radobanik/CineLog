<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--  Pages  -->

    <Style ApplyToDerivedTypes="True" TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource Background}" />
    </Style>

    <!--  Labels  -->

    <Style TargetType="Label" x:Key="HeadlineLarge">
        <Setter Property="TextColor" Value="{StaticResource OnBackground}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="HeadlineMedium">
        <Setter Property="TextColor" Value="{StaticResource OnBackground}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!--  Section header  -->
    <Style TargetType="Label" x:Key="SectionHeader">
        <Setter Property="TextColor" Value="{StaticResource OnBackground}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1.5" />
        <Setter Property="TextTransform" Value="Uppercase" />
    </Style>

    <!--  Accent text  -->
    <Style TargetType="Label" x:Key="AccentLabel">
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="BodyLarge">
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="Label" x:Key="BodyMedium">
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Label" x:Key="Caption">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!--  Font Awesome icons  -->
    <Style TargetType="Label" x:Key="Icon">
        <Setter Property="FontFamily" Value="FASolid" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="FontSize" Value="18" />
    </Style>

    <Style TargetType="Label" x:Key="PrimaryIcon">
        <Setter Property="FontFamily" Value="FASolid" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="18" />
    </Style>

    <!--  Buttons  -->

    <!--  Primary button  -->
    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="{StaticResource OnPrimary}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="20,0" />
    </Style>

    <!--  Secondary button  -->
    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="20,0" />
    </Style>

    <!--  Text-only button  -->
    <Style TargetType="Button" x:Key="TextButton">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!--  Entries  -->

    <Style TargetType="Entry" x:Key="FormEntry">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariant}" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <!--  Misc  -->

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource Primary}" />
    </Style>

    <!--  Pill-shaped input field container  -->
    <Style TargetType="Border" x:Key="InputField">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariant}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="28" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Borderless entry inside InputField  -->
    <Style TargetType="Entry" x:Key="CleanEntry">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin" Value="0" />
    </Style>

</ResourceDictionary>
